#!/usr/bin/env bash
set -euo pipefail

########################################
# Resolve install directory
########################################

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
BIN_DIR="$(dirname "$SCRIPT_PATH")"
INSTALL_DIR="$(cd "$BIN_DIR/.." && pwd)"

export INSTALL_DIR

########################################
# Load runtime + libraries
########################################

source "$INSTALL_DIR/lib/runtime.sh"
source "$LIB_DIR/compose.sh"
source "$LIB_DIR/services.sh"
source "$LIB_DIR/ports.sh"

########################################
# Load environment
########################################

if [[ -f "$CORE_DIR/env.sh" ]]; then
    source "$CORE_DIR/env.sh"
fi

COMMAND="${1:-help}"

########################################
# Help Menu
########################################

show_help() {

echo ""
echo "Media Stack CLI"
echo ""
echo "Commands:"
echo ""
echo "media-stack install"
echo "media-stack update"
echo "media-stack status"
echo "media-stack services"
echo "media-stack doctor"
echo "media-stack verify"
echo "media-stack restart"
echo "media-stack logs [service]"
echo "media-stack maintenance"
echo "media-stack backup"
echo "media-stack reset"
echo "media-stack version"
echo ""
}

########################################
# Install Stack
########################################

install_stack() {

cd "$INSTALL_DIR"
bash installer.sh

}

########################################
# Update Stack
########################################

update_stack() {

bash "$SCRIPT_DIR/updates.sh"

}

########################################
# Stack Status
########################################

status_stack() {

compose_status

}

########################################
# List Services
########################################

services_stack() {

require_command jq

if [[ -f "$SERVICE_REGISTRY" ]]; then
    jq -r '.services[] | "\(.name) -> \(.url)"' "$SERVICE_REGISTRY"
else
    echo "services.json not found"
fi

}

########################################
# Doctor
########################################

doctor_stack() {

bash "$SCRIPT_DIR/doctor.sh"

}

########################################
# Verify System
########################################

verify_stack() {

echo ""
echo "================================"
echo "Media Stack Verification"
echo "================================"
echo ""

bash "$SCRIPT_DIR/preflight.sh"
bash "$SCRIPT_DIR/plugin-validator.sh"
bash "$SCRIPT_DIR/doctor.sh"

compose_validate

echo ""
echo "Verification complete."
echo ""

}

########################################
# Restart Containers
########################################

restart_stack() {

compose_restart

}

########################################
# Logs
########################################

logs_stack() {

compose_logs "${2:-}"

}

########################################
# Maintenance
########################################

maintenance_stack() {

docker image prune -f
docker container prune -f
docker volume prune -f

}

########################################
# Backup
########################################

backup_stack() {

bash "$SCRIPT_DIR/backup.sh"

}

########################################
# Reset
########################################

reset_stack() {

bash "$INSTALL_DIR/reset-stack.sh"

}

########################################
# Version
########################################

version_stack() {

if [[ -f "$INSTALL_DIR/VERSION" ]]; then
    echo "Media Stack version: $(cat "$INSTALL_DIR/VERSION")"
else
    echo "Media Stack version unknown"
fi

}

########################################
# Command Router
########################################

case "$COMMAND" in

install)
install_stack
;;

update)
update_stack
;;

status)
status_stack
;;

services)
services_stack
;;

doctor)
doctor_stack
;;

verify)
verify_stack
;;

restart)
restart_stack
;;

logs)
logs_stack "$@"
;;

maintenance)
maintenance_stack
;;

backup)
backup_stack
;;

reset)
reset_stack
;;

version)
version_stack
;;

*)
show_help
;;

esac