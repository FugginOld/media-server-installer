#!/usr/bin/env bash

STACK_DIR="/opt/media-stack"
INSTALL_DIR="/opt/media-server-installer"
CLI="/usr/local/bin/media-stack"

########################################
# NEW: Validate installer exists
########################################

if [ ! -d "$INSTALL_DIR" ]; then
echo "Media Stack installer not found at:"
echo "$INSTALL_DIR"
echo ""
echo "Please reinstall the stack."
exit 1
fi

show_help() {

echo ""
echo "Media Stack CLI"
echo ""
echo "Commands:"
echo ""
echo "media-stack install"
echo "media-stack update"
echo "media-stack status"
echo "media-stack services"
echo "media-stack restart"
echo "media-stack logs"
echo "media-stack maintenance"
echo "media-stack backup"
echo "media-stack reset"
echo "media-stack doctor"
echo ""

}

install_stack() {

cd "$INSTALL_DIR" || exit
bash installer.sh

}

update_stack() {

bash "$INSTALL_DIR/scripts/updates.sh"

}

status_stack() {

########################################
# Uses compose helper for status
########################################

bash "$INSTALL_DIR/scripts/compose.sh" status

}

services_stack() {

if [ -f "$STACK_DIR/services.json" ]; then

cat "$STACK_DIR/services.json" \
| jq -r '.services[] | "\(.name) -> \(.url)"'

else

echo "services.json not found"

fi

}

restart_stack() {

bash "$INSTALL_DIR/scripts/compose.sh" restart

}

logs_stack() {

bash "$INSTALL_DIR/scripts/compose.sh" logs

}

backup_stack() {

bash "$INSTALL_DIR/scripts/backup.sh"

}

maintenance_stack() {

########################################
# Existing cleanup tasks
########################################

docker image prune -f
docker container prune -f

########################################
# Pull updated images if compose exists
########################################

if [ -f "$INSTALL_DIR/scripts/compose.sh" ]; then
bash "$INSTALL_DIR/scripts/compose.sh" pull
fi

}

reset_stack() {

echo "Resetting Media Stack..."

bash "$INSTALL_DIR/reset-stack.sh"

}

########################################
# NEW: Diagnostic command
########################################

doctor_stack() {

bash "$INSTALL_DIR/scripts/doctor.sh"

}

case "$1" in

install)
install_stack
;;

update)
update_stack
;;

status)
status_stack
;;

services)
services_stack
;;

restart)
restart_stack
;;

logs)
logs_stack
;;

maintenance)
maintenance_stack
;;

backup)
backup_stack
;;

reset)
reset_stack
;;

doctor)
doctor_stack
;;

*)
show_help
;;

esac