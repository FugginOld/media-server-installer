#!/usr/bin/env bash

########################################
# Media Stack CLI
#
# Command line interface for managing
# the Media Stack installation.
########################################

set -e

########################################
# Determine installer directory
########################################

INSTALL_DIR="/opt/media-server-installer"

########################################
# Load environment
########################################

source "$INSTALL_DIR/core/env.sh"

########################################
# Help Menu
########################################

show_help() {

echo ""
echo "Media Stack CLI"
echo ""
echo "Commands:"
echo ""
echo "media-stack install"
echo "media-stack update"
echo "media-stack status"
echo "media-stack services"
echo "media-stack doctor"
echo "media-stack verify"
echo "media-stack restart"
echo "media-stack logs"
echo "media-stack maintenance"
echo "media-stack backup"
echo "media-stack reset"
echo "media-stack version"
echo ""

}

########################################
# Install Stack
########################################

install_stack() {

cd "$INSTALL_DIR"
bash installer.sh

}

########################################
# Update Stack
########################################

update_stack() {

bash "$INSTALL_DIR/scripts/updates.sh"

}

########################################
# Stack Status
########################################

status_stack() {

bash "$INSTALL_DIR/scripts/compose.sh" status

}

########################################
# List Services
########################################

services_stack() {

if [ -f "$SERVICE_REGISTRY" ]; then

jq -r '.services[] | "\(.name) -> \(.url)"' \
"$SERVICE_REGISTRY"

else

echo "services.json not found"

fi

}

########################################
# Doctor
########################################

doctor_stack() {

bash "$INSTALL_DIR/scripts/doctor.sh"

}

########################################
# Verify System
########################################

verify_stack() {

echo ""
echo "================================"
echo " Media Stack Verification"
echo "================================"
echo ""

bash "$INSTALL_DIR/scripts/preflight.sh"
bash "$INSTALL_DIR/scripts/plugin-validator.sh"
bash "$INSTALL_DIR/scripts/doctor.sh"
bash "$INSTALL_DIR/scripts/compose.sh" validate

echo ""
echo "Verification complete."
echo ""

}

########################################
# Restart Containers
########################################

restart_stack() {

bash "$INSTALL_DIR/scripts/compose.sh" restart

}

########################################
# Logs
########################################

logs_stack() {

bash "$INSTALL_DIR/scripts/compose.sh" logs "$2"

}

########################################
# Maintenance
########################################

maintenance_stack() {

docker image prune -f
docker container prune -f
docker volume prune -f

}

########################################
# Backup
########################################

backup_stack() {

bash "$INSTALL_DIR/scripts/backup.sh"

}

########################################
# Reset
########################################

reset_stack() {

bash "$INSTALL_DIR/reset-stack.sh"

}

########################################
# Version
########################################

version_stack() {

if [ -f "$STACK_DIR/version" ]; then
echo "Media Stack version: $(cat $STACK_DIR/version)"
else
echo "Media Stack version unknown"
fi

}

########################################
# Command Router
########################################

case "$1" in

install)
install_stack
;;

update)
update_stack
;;

status)
status_stack
;;

services)
services_stack
;;

doctor)
doctor_stack
;;

verify)
verify_stack
;;

restart)
restart_stack
;;

logs)
logs_stack "$@"
;;

maintenance)
maintenance_stack
;;

backup)
backup_stack
;;

reset)
reset_stack
;;

version)
version_stack
;;

*)
show_help
;;

esac