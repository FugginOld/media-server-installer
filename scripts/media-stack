#!/usr/bin/env bash

STACK_DIR="/opt/media-stack"
INSTALL_DIR="/opt/media-server-installer"

########################################
# Ensure installer exists
########################################

check_installer() {

if [ ! -d "$INSTALL_DIR" ]; then
    echo "Media Stack installer not found."
    exit 1
fi

}

########################################
# Help menu
########################################

show_help() {

echo ""
echo "================================"
echo " Media Stack CLI"
echo "================================"
echo ""

echo "Commands:"
echo ""

echo "media-stack install      Install stack"
echo "media-stack update       Update containers"
echo "media-stack status       Show container status"
echo "media-stack services     List services"
echo "media-stack restart      Restart stack"
echo "media-stack logs         View logs"
echo "media-stack backup       Backup configuration"
echo "media-stack doctor       Diagnose stack"
echo "media-stack maintenance  Clean Docker"
echo "media-stack reset        Remove stack"

echo ""

}

########################################
# Install stack
########################################

install_stack() {

check_installer
cd "$INSTALL_DIR" || exit
bash installer.sh

}

########################################
# Update stack
########################################

update_stack() {

check_installer
bash "$INSTALL_DIR/scripts/updates.sh"

}

########################################
# Status
########################################

status_stack() {

check_installer
bash "$INSTALL_DIR/scripts/compose.sh" status

}

########################################
# Services
########################################

services_stack() {

if [ -f "$STACK_DIR/services.json" ]; then

cat "$STACK_DIR/services.json" \
| jq -r '.services[] | "\(.name) -> \(.url)"'

else

echo "services.json not found"

fi

}

########################################
# Restart stack
########################################

restart_stack() {

check_installer
bash "$INSTALL_DIR/scripts/compose.sh" restart

}

########################################
# Logs
########################################

logs_stack() {

check_installer
bash "$INSTALL_DIR/scripts/compose.sh" logs

}

########################################
# Backup
########################################

backup_stack() {

check_installer
bash "$INSTALL_DIR/scripts/backup.sh"

}

########################################
# Diagnostics
########################################

doctor_stack() {

check_installer
bash "$INSTALL_DIR/scripts/doctor.sh"

}

########################################
# Maintenance
########################################

maintenance_stack() {

echo "Cleaning unused Docker resources..."

docker image prune -f
docker container prune -f

}

########################################
# Reset stack
########################################

reset_stack() {

check_installer

echo "Resetting Media Stack..."

bash "$INSTALL_DIR/reset-stack.sh"

}

########################################
# Command router
########################################

case "$1" in

install)
install_stack
;;

update)
update_stack
;;

status)
status_stack
;;

services)
services_stack
;;

restart)
restart_stack
;;

logs)
logs_stack
;;

backup)
backup_stack
;;

doctor)
doctor_stack
;;

maintenance)
maintenance_stack
;;

reset)
reset_stack
;;

*)
show_help
;;

esac