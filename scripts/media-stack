#!/usr/bin/env bash

########################################
# Media Stack CLI
#
# Command line interface for managing
# the Media Stack installation.
########################################

STACK_DIR="/opt/media-stack"
INSTALL_DIR="/opt/media-server-installer"

########################################
# Help menu
########################################

show_help() {

echo ""
echo "================================"
echo " Media Stack CLI"
echo "================================"
echo ""

echo "Commands:"
echo ""

echo "media-stack install      Install stack"
echo "media-stack update       Update containers"
echo "media-stack status       Show container status"
echo "media-stack services     List registered services"
echo "media-stack restart      Restart containers"
echo "media-stack logs         View container logs"
echo "media-stack backup       Backup stack"
echo "media-stack doctor       Diagnose stack"
echo "media-stack maintenance  Clean docker resources"
echo "media-stack reset        Remove stack"

echo ""

}

########################################
# Install stack
########################################

install_stack() {

cd "$INSTALL_DIR" || exit
bash installer.sh

}

########################################
# Update containers
########################################

update_stack() {

bash "$INSTALL_DIR/scripts/updates.sh"

}

########################################
# Show container status
########################################

status_stack() {

bash "$INSTALL_DIR/scripts/compose.sh" status

}

########################################
# List registered services
########################################

services_stack() {

if [ -f "$STACK_DIR/services.json" ]; then

cat "$STACK_DIR/services.json" \
| jq -r '.services[] | "\(.name) -> \(.url)"'

else

echo "services.json not found"

fi

}

########################################
# Restart containers
########################################

restart_stack() {

bash "$INSTALL_DIR/scripts/compose.sh" restart

}

########################################
# Show container logs
########################################

logs_stack() {

bash "$INSTALL_DIR/scripts/compose.sh" logs

}

########################################
# Backup stack
########################################

backup_stack() {

bash "$INSTALL_DIR/scripts/backup.sh"

}

########################################
# Run diagnostics
########################################

doctor_stack() {

bash "$INSTALL_DIR/scripts/doctor.sh"

}

########################################
# Clean docker resources
########################################

maintenance_stack() {

echo "Cleaning unused Docker resources..."

docker image prune -f
docker container prune -f

}

########################################
# Reset stack
########################################

reset_stack() {

echo "Resetting Media Stack..."

bash "$INSTALL_DIR/reset-stack.sh"

}

########################################
# Command router
########################################

case "$1" in

install)
install_stack
;;

update)
update_stack
;;

status)
status_stack
;;

services)
services_stack
;;

restart)
restart_stack
;;

logs)
logs_stack
;;

backup)
backup_stack
;;

doctor)
doctor_stack
;;

maintenance)
maintenance_stack
;;

reset)
reset_stack
;;

*)
show_help
;;

esac